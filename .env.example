ANTHROPIC_API_KEY=your-api-key-here

# Neon Postgres (optional — falls back to in-memory if not set)
DATABASE_URL=postgresql://user:pass@ep-xyz.us-east-1.aws.neon.tech/neondb?sslmode=require

# Arthur Engine tracing (optional — set all three to enable)
ARTHUR_BASE_URL=http://localhost:3030
ARTHUR_API_KEY=your-arthur-api-key
ARTHUR_TASK_ID=your-agentic-task-id
